---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
---

<Layout title="Andrew Smith - Software Engineer">
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-20">
    <div class="mb-6 flex items-center gap-4">
      <div class="h-px w-12 bg-primary"></div>
      <span class="font-mono text-[10px] tracking-[0.3em] text-text-muted uppercase">Software Engineer</span>
    </div>

    <h1 class="headline-italic text-6xl md:text-8xl lg:text-9xl leading-[0.9] tracking-tight text-text-primary mb-10">
      Andrew<br />
      <span class="text-primary">Smith</span>
    </h1>

    <p class="font-body text-lg md:text-xl text-text-secondary max-w-2xl leading-relaxed mb-8">
      Nine years building production web applications across Vue, React, and Next.js.
      I build self-hosted tools, contribute to open source, and use AI to ship faster.
      Everything here is open-source and running on my home server.
    </p>

    <div class="flex items-center gap-6">
      <a href="/#projects" class="bg-primary text-bg-base font-label text-xs font-bold px-8 py-3.5 uppercase tracking-widest hover:bg-white transition-colors rounded-md">
        View Projects
      </a>
      <a href="/history" class="border border-border-ghost text-primary-soft font-label text-xs px-8 py-3.5 uppercase tracking-widest hover:border-primary/40 hover:bg-surface-low/50 transition-all rounded-md">
        Experience
      </a>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="max-w-6xl mx-auto px-6 pb-24">
    <div class="flex items-center gap-4 mb-10">
      <span class="font-mono text-xs text-primary tracking-widest">01</span>
      <h2 class="headline-italic text-3xl text-text-primary">Projects</h2>
      <div class="flex-1 h-px bg-gradient-to-r from-border-ghost to-transparent"></div>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group block border border-border-ghost bg-surface-low p-8 glow-hover-primary transition-all rounded-lg overflow-hidden relative"
        >
          {/* Placeholder image area — gradient based on project color */}
          <div class="h-40 -mx-8 -mt-8 mb-6 overflow-hidden">
            <div
              class="w-full h-full img-reveal"
              style={`background: linear-gradient(135deg, ${project.color}22 0%, #131313 50%, ${project.color}11 100%);`}
            >
              <div class="w-full h-full flex items-center justify-center">
                <span class="headline-italic text-4xl text-text-primary/10 group-hover:text-text-primary/20 transition-colors">
                  {project.title}
                </span>
              </div>
            </div>
          </div>

          <div class="flex items-start justify-between mb-3">
            <h3 class="headline-italic text-2xl text-text-primary group-hover:text-primary-soft transition-colors">
              {project.title}
            </h3>
            <div class="flex items-center gap-2 shrink-0">
              {project.demo && (
                <span class="font-mono text-[10px] px-2.5 py-1 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wider rounded">
                  Live
                </span>
              )}
            </div>
          </div>

          <p class="text-text-secondary text-sm mb-5 leading-relaxed">{project.tagline}</p>

          <div class="flex flex-wrap gap-2">
            {project.tech.slice(0, 4).map((t) => (
              <span class="font-mono text-[10px] px-2.5 py-1 bg-surface-high text-primary-soft/80 border border-border-ghost hover:border-primary/30 transition-colors rounded">
                {t}
              </span>
            ))}
            {project.tech.length > 4 && (
              <span class="font-mono text-[10px] px-2.5 py-1 bg-surface-high text-text-muted rounded">
                +{project.tech.length - 4}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Philosophy -->
  <section class="max-w-6xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
      <div class="space-y-4 group">
        <span class="font-mono text-[10px] text-primary tracking-widest">01</span>
        <h3 class="headline-italic text-3xl text-text-primary group-hover:text-primary transition-colors">
          Full-Stack<br />Builder.
        </h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          From database schema to deployment pipeline. I ship complete applications
          with auth, cron jobs, API integrations, and mobile-responsive UIs.
        </p>
      </div>
      <div class="space-y-4 group">
        <span class="font-mono text-[10px] text-secondary tracking-widest">02</span>
        <h3 class="headline-italic text-3xl text-text-primary group-hover:text-secondary transition-colors">
          AI-Augmented<br />Engineering.
        </h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Every project here was built with Claude Code as a development partner.
          I coach teams on effective AI workflows and drive adoption across engineering orgs.
        </p>
      </div>
      <div class="space-y-4 group">
        <span class="font-mono text-[10px] text-tertiary-soft tracking-widest">03</span>
        <h3 class="headline-italic text-3xl text-text-primary group-hover:text-tertiary-soft transition-colors">
          Self-Hosted<br />by Default.
        </h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Running on a Synology NAS behind a reverse proxy. No vendor lock-in,
          no subscription fees. Docker Compose, SQLite, and full control over the stack.
        </p>
      </div>
    </div>
  </section>
</Layout>
