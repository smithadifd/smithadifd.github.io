---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
---

<Layout title="Andrew Smith - Software Engineer">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
      Hi, I'm Andrew.
    </h1>
    <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mb-6">
      I build self-hosted web applications for personal use &mdash; game deal trackers,
      investment dashboards, Pokemon team planners, and automation tools. Everything
      here is open-source and deployed on my home server.
    </p>
    <div class="flex items-center gap-3 text-sm">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-accent/10 text-accent-light border border-accent/20">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        Built with Claude Code
      </span>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="max-w-5xl mx-auto px-6 pb-20">
    <h2 class="text-2xl font-semibold text-white mb-8">Projects</h2>
    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group block rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 hover:border-zinc-700 hover:bg-zinc-900 transition-all"
        >
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-xl font-semibold text-white group-hover:text-accent-light transition-colors">
              {project.title}
            </h3>
            <div class="flex items-center gap-2 shrink-0">
              {project.demo && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                  Live Demo
                </span>
              )}
              <span class="w-3 h-3 rounded-full mt-0.5" style={`background: ${project.color}`} />
            </div>
          </div>
          <p class="text-zinc-400 text-sm mb-4">{project.tagline}</p>
          <div class="flex flex-wrap gap-1.5">
            {project.tech.slice(0, 5).map((t) => (
              <span class="text-xs px-2 py-0.5 rounded bg-zinc-800 text-zinc-400">{t}</span>
            ))}
            {project.tech.length > 5 && (
              <span class="text-xs px-2 py-0.5 rounded bg-zinc-800 text-zinc-500">
                +{project.tech.length - 5}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Claude Code Callout -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="rounded-xl border border-accent/20 bg-accent/5 p-8">
      <h2 class="text-xl font-semibold text-white mb-3">Built with Claude Code</h2>
      <p class="text-zinc-400 leading-relaxed max-w-3xl">
        Every project in this portfolio was built using
        <a href="https://claude.ai/claude-code" class="text-accent-light hover:text-white transition-colors" target="_blank" rel="noopener">Claude Code</a>
        as a development partner. From initial scaffolding through architecture decisions, debugging, and deployment &mdash;
        Claude Code was involved at every stage. This portfolio site itself was generated in a single session.
      </p>
    </div>
  </section>
</Layout>
