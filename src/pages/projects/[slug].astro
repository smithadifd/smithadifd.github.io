---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
};

const { project } = Astro.props;
---

<Layout title={`${project.title} - Andrew Smith`} description={project.description}>
  <article class="max-w-6xl mx-auto px-6 pt-12 pb-20">
    <!-- Back link -->
    <a href="/" class="inline-flex items-center gap-2 font-mono text-xs text-text-muted hover:text-primary-soft transition-colors mb-12 uppercase tracking-widest">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      All Projects
    </a>

    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-16">
      <div class="lg:col-span-8">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-2 h-2 rounded-full animate-pulse" style={`background: ${project.color}; box-shadow: 0 0 12px ${project.color};`}></div>
          <span class="font-mono text-[10px] text-text-muted tracking-[0.3em] uppercase">Project</span>
        </div>

        <h1 class="headline-italic text-5xl md:text-7xl text-text-primary tracking-tight mb-4" transition:name={`title-${project.slug}`}>
          {project.title}
        </h1>

        <p class="text-xl text-primary-soft/80 mb-4">{project.tagline}</p>
        <p class="text-text-secondary leading-relaxed max-w-2xl">{project.description}</p>

        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a
            href={project.github}
            class="inline-flex items-center gap-2 bg-primary text-bg-base font-label text-xs font-bold px-6 py-3 uppercase tracking-widest hover:bg-white transition-colors rounded-md"
            target="_blank"
            rel="noopener"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            View Source
          </a>
          {project.demo && (
            <a
              href={project.demo}
              class="inline-flex items-center gap-2 border border-border-ghost text-primary-soft font-label text-xs px-6 py-3 uppercase tracking-widest hover:border-primary/40 transition-all rounded-md"
              target="_blank"
              rel="noopener"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              Live Demo
            </a>
          )}
        </div>

        {project.demo && (
          <div class="mt-6 border border-border-ghost bg-surface-low p-5 rounded-lg">
            <p class="font-mono text-[10px] text-text-muted mb-2 uppercase tracking-widest">Demo Credentials</p>
            <p class="text-sm text-text-secondary">
              <span class="text-text-muted">Email:</span> <span class="text-primary-soft/80 font-mono text-xs">demo@example.com</span>
              <span class="text-text-muted ml-4">Password:</span> <span class="text-primary-soft/80 font-mono text-xs">demo1234!</span>
            </p>
            <p class="text-xs text-text-muted mt-2">Read-only mode &mdash; data resets weekly. Access restricted to US/Canada.</p>
          </div>
        )}
      </div>

      <!-- Metrics sidebar -->
      {project.metrics && project.metrics.length > 0 && (
        <aside class="lg:col-span-4 space-y-1">
          <p class="font-mono text-[10px] text-text-muted uppercase tracking-widest mb-4">Key Metrics</p>
          {project.metrics.map((m) => (
            <div class="bg-surface-low border border-border-ghost p-5 rounded-lg">
              <span class="font-mono text-[10px] text-text-muted uppercase tracking-widest block mb-1">{m.label}</span>
              <span class="headline-italic text-2xl text-primary">{m.value}</span>
            </div>
          ))}
        </aside>
      )}
    </div>

    <!-- Content sections -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-8 space-y-16">
        <!-- Tech Stack -->
        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="font-mono text-xs text-primary tracking-widest">01</span>
            <h2 class="headline-italic text-2xl text-text-primary">Tech Stack</h2>
            <div class="flex-1 h-px bg-gradient-to-r from-border-ghost to-transparent"></div>
          </div>
          <div class="flex flex-wrap gap-2">
            {project.tech.map((t: string) => (
              <span class="font-mono text-[11px] px-3.5 py-1.5 bg-surface-high text-primary-soft/80 border border-border-ghost hover:border-primary/30 transition-colors rounded">
                {t}
              </span>
            ))}
          </div>
        </section>

        <!-- Motivation -->
        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="font-mono text-xs text-primary tracking-widest">02</span>
            <h2 class="headline-italic text-2xl text-text-primary">Why I Built This</h2>
            <div class="flex-1 h-px bg-gradient-to-r from-border-ghost to-transparent"></div>
          </div>
          <p class="text-text-secondary leading-relaxed text-base">{project.motivation}</p>
        </section>

        <!-- Features -->
        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="font-mono text-xs text-primary tracking-widest">03</span>
            <h2 class="headline-italic text-2xl text-text-primary">Features</h2>
            <div class="flex-1 h-px bg-gradient-to-r from-border-ghost to-transparent"></div>
          </div>
          <ul class="space-y-3">
            {project.features.map((f: string) => (
              <li class="flex items-start gap-3 text-text-secondary leading-relaxed">
                <span class="text-primary mt-1.5 shrink-0 w-1 h-1 rounded-full bg-primary"></span>
                {f}
              </li>
            ))}
          </ul>
        </section>

        <!-- Architecture -->
        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="font-mono text-xs text-primary tracking-widest">04</span>
            <h2 class="headline-italic text-2xl text-text-primary">Architecture</h2>
            <div class="flex-1 h-px bg-gradient-to-r from-border-ghost to-transparent"></div>
          </div>
          <p class="text-text-secondary leading-relaxed text-base">{project.architecture}</p>
        </section>

        <!-- Key Decisions -->
        <section>
          <div class="flex items-center gap-4 mb-6">
            <span class="font-mono text-xs text-primary tracking-widest">05</span>
            <h2 class="headline-italic text-2xl text-text-primary">Key Decisions</h2>
            <div class="flex-1 h-px bg-gradient-to-r from-border-ghost to-transparent"></div>
          </div>
          <div class="space-y-4">
            {project.decisions.map((d: { title: string; detail: string }) => (
              <div class="border border-border-ghost bg-surface-low p-6 glow-hover-primary rounded-lg">
                <h3 class="font-label font-medium text-text-primary mb-2">{d.title}</h3>
                <p class="text-sm text-text-secondary leading-relaxed">{d.detail}</p>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </article>
</Layout>
