---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
};

const { project } = Astro.props;
---

<Layout title={`${project.title} - Andrew Smith`} description={project.description}>
  <article class="max-w-3xl mx-auto px-6 pt-12 pb-20">
    <!-- Back link -->
    <a href="/" class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-white transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      All projects
    </a>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="w-3 h-3 rounded-full" style={`background: ${project.color}`} />
        <h1 class="text-3xl md:text-4xl font-bold text-white">{project.title}</h1>
      </div>
      <p class="text-xl text-zinc-400 mb-4">{project.tagline}</p>
      <p class="text-zinc-300 leading-relaxed">{project.description}</p>
      <div class="mt-4 flex items-center gap-4">
        <a
          href={project.github}
          class="inline-flex items-center gap-2 text-sm text-accent-light hover:text-white transition-colors"
          target="_blank"
          rel="noopener"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
        {project.demo && (
          <a
            href={project.demo}
            class="inline-flex items-center gap-2 text-sm text-emerald-400 hover:text-white transition-colors"
            target="_blank"
            rel="noopener"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            Live Demo
          </a>
        )}
      </div>
      {project.demo && (
        <div class="mt-4 rounded-lg border border-zinc-800 bg-zinc-900/50 px-4 py-3">
          <p class="text-xs text-zinc-500 mb-1.5">Demo credentials</p>
          <p class="text-sm text-zinc-300">
            <span class="text-zinc-500">Email:</span> demo@example.com
            <span class="text-zinc-500 ml-3">Password:</span> demo1234!
          </p>
          <p class="text-xs text-zinc-500 mt-1.5">Read-only mode &mdash; data resets weekly.</p>
        </div>
      )}
    </div>

    <!-- Tech Stack -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-3">Tech Stack</h2>
      <div class="flex flex-wrap gap-2">
        {project.tech.map((t: string) => (
          <span class="text-sm px-3 py-1 rounded-lg bg-zinc-800 text-zinc-300 border border-zinc-700">
            {t}
          </span>
        ))}
      </div>
    </section>

    <!-- Motivation -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-3">Why I Built This</h2>
      <p class="text-zinc-300 leading-relaxed">{project.motivation}</p>
    </section>

    <!-- Features -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-3">Features</h2>
      <ul class="space-y-2">
        {project.features.map((f: string) => (
          <li class="flex items-start gap-2 text-zinc-300">
            <span class="text-accent-light mt-1 shrink-0">&#8226;</span>
            {f}
          </li>
        ))}
      </ul>
    </section>

    <!-- Architecture -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-3">Architecture</h2>
      <p class="text-zinc-300 leading-relaxed">{project.architecture}</p>
    </section>

    <!-- Key Decisions -->
    <section class="mb-10">
      <h2 class="text-lg font-semibold text-white mb-3">Key Decisions</h2>
      <div class="space-y-4">
        {project.decisions.map((d: { title: string; detail: string }) => (
          <div class="rounded-lg border border-zinc-800 bg-zinc-900/50 p-4">
            <h3 class="font-medium text-white mb-1">{d.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{d.detail}</p>
          </div>
        ))}
      </div>
    </section>
  </article>
</Layout>
